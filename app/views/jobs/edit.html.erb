<%= render "shared/dashboard_nav" %>

<div class="job-form-page page-shell">
  <div class="page-container job-form-page__container">
    <div class="job-form-page__header job-form-page__header--with-action">
      <div>
        <h1 class="job-form-page__title">Edit Job</h1>
        <p class="job-form-page__intro">Update role details and status.</p>
      </div>
      <%= link_to "View", job_path(@job), class: "btn btn--ghost" %>
    </div>

    <div class="job-form-layout">
      <div class="job-form-layout__sidebar">
        <div id="job_ai_preview_wrapper" class="ai-preview-wrapper">
          <div id="job_ai_preview_loader" class="job-ai-preview-loader" aria-hidden="true">
            <%= render "ai_preview_loader" %>
          </div>

          <%= render "ai_preview_frame", job: @job %>
        </div>
      </div>
      <div class="job-form-layout__main">
        <%= turbo_frame_tag "job_form" do %>
          <div class="job-entry-form-card">
            <%= render "form", job: @job %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
