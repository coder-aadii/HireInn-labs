<nav class="dashboard-nav">
  <div class="page-container dashboard-nav__inner">
    <%= link_to home_index_path, class: "dashboard-nav__brand" do %>
      <%= image_tag "hireinn_logo.png", alt: "HireInn Labs logo", class: "dashboard-nav__logo" %>
      <span class="dashboard-nav__name">HireInn Labs</span>
      <span class="dashboard-nav__role"><%= current_user.admin? ? "Admin" : "HR" %></span>
    <% end %>

    <div class="dashboard-nav__links">
      <%= link_to "Dashboard", dashboard_path, class: "dashboard-nav__link #{'is-active' if current_page?(dashboard_path)}" %>
      <%= link_to "Jobs", jobs_path, class: "dashboard-nav__link #{'is-active' if controller_name == 'jobs'}" %>
      <%= link_to "Candidates", "#", class: "dashboard-nav__link" %>
      <%= link_to "Applications", applications_path, class: "dashboard-nav__link #{'is-active' if controller_name == 'applications'}" %>
      <%= link_to "Interviews", "#", class: "dashboard-nav__link" %>
    </div>

    <div class="dashboard-nav__actions">
      <%= link_to "Career Page", careers_path, class: "btn btn--primary" %>
      <% if current_user.admin? %>
        <%= link_to "Admin", "#", class: "btn btn--ghost" %>
      <% end %>
      <%= button_to "Log out", destroy_user_session_path,
          method: :delete,
          form_class: "nav-inline-form",
          class: "btn btn--outline" %>
    </div>
  </div>
</nav>
