<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Hire Inn Labs" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Hire Inn Labs">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "intlTelInput-no-assets", "data-turbo-track": "reload" %>
    <style>
      :root {
        --iti-path-flags-1x: url("<%= asset_path('flags.webp') %>");
        --iti-path-flags-2x: url("<%= asset_path('flags@2x.webp') %>");
      }
    </style>

    <%# Includes app/assets/builds/application.css (from cssbundling-rails) %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "intlTelInputWithUtils.min", "data-turbo-track": "reload", defer: true %>
    <%= javascript_importmap_tags %>
  </head>

  <% body_class = content_for?(:body_class) ? content_for(:body_class) : nil %>
  <% public_cursor = body_class.to_s.include?("landing-page") ? "public-cursor" : nil %>
  <body class="<%= [body_class, public_cursor, (user_signed_in? ? "app-shell" : nil)].compact.join(" ") %>">
    <div id="cursor-root" aria-hidden="true" data-cursor-image="<%= image_path("hireinn_logo.png") %>"></div>
    <div id="flash">
      <%= render "shared/flash" %>
    </div>
    <%= yield %>
  </body>
</html>
