<%= render "shared/dashboard_nav" %>

<div class="profiles-page page-shell">
  <div class="page-container profiles-page__container">
    <header class="profiles-header">
      <div>
        <h1 class="profiles-header__title">Edit Profile</h1>
        <p class="profiles-header__subtitle">
          Refresh your HR presence and keep your company-facing details accurate.
        </p>
      </div>
      <div class="profiles-header__badge">Update Profile</div>
    </header>

    <div class="profiles-layout">
      <section class="panel panel--glass profile-card profile-card--form">
        <div class="profile-card__header">
          <h3>Profile Information</h3>
          <p>Adjust your profile details without leaving the hiring workspace.</p>
        </div>

        <%= render "profile_form", profile: @profile %>
      </section>

      <aside class="panel panel--glass profile-card profile-card--aside">
        <h6 class="profile-card__eyebrow">Quick Snapshot</h6>
        <div class="profile-card__stat">
          <span>Account Email</span>
          <strong><%= current_user.email %></strong>
        </div>
        <div class="profile-card__stat">
          <span>Role</span>
          <strong><%= current_user.role.to_s.titleize %></strong>
        </div>
        <div class="profile-card__stat">
          <span>Company</span>
          <strong><%= @profile.company_name.presence || "Not set" %></strong>
        </div>
      </aside>
    </div>
  </div>
</div>
