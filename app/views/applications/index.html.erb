<%= render "shared/dashboard_nav" %>

<div class="applications-page page-shell">
  <div class="page-container applications-page__container">
    <header class="applications-header">
      <div>
        <h1 class="applications-header__title">Applications</h1>
        <p class="applications-header__subtitle">Review candidates who applied to your jobs.</p>
      </div>
    </header>

    <section class="panel panel--glass applications-filters">
      <%= form_with url: applications_path, method: :get, local: true, class: "applications-filters__form" do |form| %>
        <div class="applications-filters__field">
          <%= form.label :q, "Search", class: "label" %>
          <%= form.search_field :q,
                value: @search_query,
                placeholder: "Search by candidate, email, or job title",
                class: "input" %>
        </div>

        <div class="applications-filters__field">
          <%= form.label :job_id, "Job", class: "label" %>
          <%= form.select :job_id,
                options_from_collection_for_select(@jobs, :id, :title, @selected_job_id),
                { include_blank: "All jobs" },
                class: "select" %>
        </div>

        <div class="applications-filters__actions">
          <%= form.submit "Apply", class: "btn btn--primary" %>
          <% if @search_query.present? || @selected_job_id.present? %>
            <%= link_to "Clear", applications_path, class: "btn btn--outline" %>
          <% end %>
        </div>
      <% end %>
    </section>

    <% if @applications.any? %>
      <div class="applications-grid">
        <% @applications.each do |application| %>
          <div class="panel panel--glass application-card">
            <div class="application-card__header">
              <div>
                <h3 class="application-card__title"><%= application.candidate.name %></h3>
                <div class="application-card__meta"><%= application.candidate.email %></div>
              </div>
              <span class="tag tag--dark"><%= application.status.to_s.titleize %></span>
            </div>
            <div class="application-card__body">
              <span>Applied for <strong><%= application.job.title %></strong></span>
            </div>
            <div class="application-card__actions">
              <%= link_to "View", application_path(application), class: "btn btn--outline" %>
              <% if application.resume.attached? %>
                <%= link_to "Resume", rails_blob_path(application.resume, disposition: "attachment"), class: "btn btn--primary" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="panel panel--glass applications-empty">
        <h3><%= (@search_query.present? || @selected_job_id.present?) ? "No matching applications" : "No applications yet" %></h3>
        <p>
          <%= (@search_query.present? || @selected_job_id.present?) ? "Try a different search term or switch the job filter." : "Once candidates apply, they’ll appear here." %>
        </p>
      </div>
    <% end %>
  </div>
</div>
