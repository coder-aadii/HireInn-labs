<% content_for :body_class, "landing-page" %>

<%= render "shared/home_navbar" %>

<div class="landing auth-page page-shell">
  <div class="page-container auth-page__container">
    <div class="auth-stage">
      <section class="auth-showcase">
        <div class="auth-showcase__content">
          <div class="auth-showcase__badge">Recovery</div>
          <h2 class="auth-showcase__title">Get back into your workspace without the friction.</h2>
          <p class="auth-showcase__text">
            We’ll send secure reset instructions to the email associated with your account so you can return to work quickly and safely.
          </p>

          <div class="auth-showcase__stats">
            <div class="auth-showcase__stat">
              <strong>Secure</strong>
              <span>Only registered accounts receive reset instructions.</span>
            </div>
            <div class="auth-showcase__stat">
              <strong>Fast</strong>
              <span>Reset flows are designed to get you back in quickly.</span>
            </div>
            <div class="auth-showcase__stat">
              <strong>Reliable</strong>
              <span>Use the latest reset email if multiple arrive.</span>
            </div>
          </div>
        </div>

        <div class="auth-showcase__footer">
          <p class="auth-showcase__quote">
            “Recovery screens should feel reassuring, not like a dead end.”
            <strong>HireInn Labs</strong>
          </p>
        </div>
      </section>

      <section class="auth-pane">
        <div class="auth-card__eyebrow">Recovery</div>
        <h1 class="auth-card__title">Reset your password</h1>
        <p class="auth-card__intro">
          Enter the email tied to your HireInn Labs account and we’ll send secure reset instructions so you can get back in quickly.
        </p>

        <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "auth-form" }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div class="auth-form__grid">
            <div class="auth-form__field auth-form__field--full">
              <%= f.label :email, class: "label" %>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input--large", placeholder: "you@company.com" %>
            </div>
          </div>

          <div class="auth-form__actions">
            <div class="auth-form__meta">We’ll email secure reset instructions</div>
            <%= f.submit "Send Reset Instructions", class: "btn btn--primary btn--large" %>
          </div>
        <% end %>

        <%= render "devise/shared/links" %>
      </section>
    </div>
  </div>
</div>
