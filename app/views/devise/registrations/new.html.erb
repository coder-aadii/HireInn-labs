<% content_for :body_class, "landing-page" %>

<%= render "shared/home_navbar" %>

<div class="landing auth-page page-shell">
  <div class="page-container auth-page__container">
    <div class="auth-stage">
      <section class="auth-showcase">
        <div class="auth-showcase__content">
          <div class="auth-showcase__badge">Create Workspace</div>
          <h2 class="auth-showcase__title">Build a hiring presence that feels as strong as your team.</h2>
          <p class="auth-showcase__text">
            From career pages to applicant handling, HireInn Labs gives HR teams a cleaner public face and a faster internal workflow.
          </p>

          <div class="auth-showcase__stats">
            <div class="auth-showcase__stat">
              <strong>Brand</strong>
              <span>Launch elegant job pages with a premium first impression.</span>
            </div>
            <div class="auth-showcase__stat">
              <strong>Flow</strong>
              <span>Collect applications and route them into one system.</span>
            </div>
            <div class="auth-showcase__stat">
              <strong>Speed</strong>
              <span>Use AI tools to move from idea to published role faster.</span>
            </div>
          </div>
        </div>

        <div class="auth-showcase__footer">
          <p class="auth-showcase__quote">
            “The first impression of your hiring product should feel intentional, not improvised.”
            <strong>HireInn Labs</strong>
          </p>
        </div>
      </section>

      <section class="auth-pane">
        <div class="auth-card__eyebrow">Create Workspace</div>
        <h1 class="auth-card__title">Start hiring with a polished command center</h1>
        <p class="auth-card__intro">
          Create your HireInn Labs account to publish roles, review applications, and manage your hiring pipeline from one premium workspace.
        </p>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div class="auth-form__grid">
            <div class="auth-form__field auth-form__field--full">
              <%= f.label :email, class: "label" %>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input--large", placeholder: "you@company.com" %>
            </div>

            <div class="auth-form__field">
              <%= f.label :password, class: "label" %>
              <%= f.password_field :password, autocomplete: "new-password", class: "input input--large", placeholder: "Create a secure password" %>
              <% if @minimum_password_length %>
                <p class="auth-form__hint"><%= @minimum_password_length %> characters minimum</p>
              <% end %>
            </div>

            <div class="auth-form__field">
              <%= f.label :password_confirmation, class: "label" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input input--large", placeholder: "Confirm your password" %>
            </div>
          </div>

          <div class="auth-form__actions">
            <div class="auth-form__meta">Set up your account in under a minute</div>
            <%= f.submit "Create Account", class: "btn btn--primary btn--large" %>
          </div>
        <% end %>

        <%= render "devise/shared/links" %>
      </section>
    </div>
  </div>
</div>
