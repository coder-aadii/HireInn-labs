# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Bundler
/.bundle
/vendor/bundle

# Environment files
/.env*

# Logs and tempfiles
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Temp subdirectories we want to preserve
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep
/tmp/cache/*
!/tmp/cache/.keep
/tmp/sockets/*
!/tmp/sockets/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep
/tmp/screenshots/*
!/tmp/screenshots/.keep

# Uploaded files and local storage
/storage/*
!/storage/.keep

# Compiled assets
/public/assets
/public/packs
/public/packs-test
/app/assets/builds/*
!/app/assets/builds/.keep

# Database
/db/*.sqlite3
/db/*.sqlite3-*

# Secrets
/config/*.key

# Node / frontend tooling
/node_modules
.yarn/*
!.yarn/releases
!.yarn/plugins
!.yarn/patches
!.yarn/sdks
!.yarn/versions
.pnp.*
.npm

# Test / coverage artifacts
/coverage
/rerun.txt
/capybara-*.html

# Debugging / local machine files
.byebug_history
.ruby-gemset*
.sass-cache
.DS_Store
Thumbs.db

# Service/runtime leftovers
/dump.rdb
